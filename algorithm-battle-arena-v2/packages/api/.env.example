# ─── Backend Environment Variables (NestJS API) ───────────────────
# Copy this file to .env and fill in real values
# This file is used for local development and Docker containers

# ─── Database ──────────────────────────────────────────────────────
# Local (Docker): postgresql://postgres:dev@localhost:5432/algorithm_battle_arena
# Supabase: postgresql://postgres.[PROJECT].supabase.co:5432/postgres?schema=public
DATABASE_URL=postgresql://postgres:dev@localhost:5432/algorithm_battle_arena

# ─── Authentication & Security ────────────────────────────────────
# JWT Secret (min 64 characters for HS512)
# Generate: openssl rand -base64 32
JWT_SECRET=local_dev_jwt_secret_key_that_is_at_least_64_characters_for_hs512_algorithm

# Password hashing key (PBKDF2 - must be consistent for existing user passwords)
PASSWORD_KEY=local_dev_password_key

# JWT Token Expiry (in seconds)
ACCESS_TOKEN_TTL_SECONDS=604800
REFRESH_TOKEN_TTL_SECONDS=2592000

# ─── Admin Account (Hardcoded in AuthService) ─────────────────────
# Used for initial login before any DB seeding
ADMIN_EMAIL=admin@aba.dev
ADMIN_PASSWORD=admin123

# ─── Redis (Socket.IO real-time, caching) ────────────────────────
# Local: redis://default:password@localhost:6379
# Upstash: redis://default:TOKEN@HOST.upstash.io:6379
REDIS_URL=redis://default:password@your-redis-host:6379
UPSTASH_REDIS_REST_URL=https://your-upstash-instance.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-rest-token

# ─── Judge0 (Code Execution) ──────────────────────────────────────
# Local Docker: http://localhost:2358
# External: http://IP:PORT with AUTH_TOKEN
JUDGE0_API_URL=http://localhost:2358
JUDGE0_URL=http://80.225.237.225:2358
JUDGE0_AUTH_TOKEN=your-judge0-auth-token
JUDGE0_MAX_POLL_ATTEMPTS=20
JUDGE0_POLL_INTERVAL_MS=500

# ─── OpenAI (Optional - for AI micro-course generation) ──────────
# Get key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-your-openai-api-key-here

# ─── Application Settings ─────────────────────────────────────────
NODE_ENV=development
PORT=5000

# ─── End of Environment Variables ──────────────────────────────────
