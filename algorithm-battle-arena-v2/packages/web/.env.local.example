# ─── Next.js Frontend Environment Variables ──────────────────────
# Copy this file to .env.local (NOT committed to git)
# These variables are prefixed with NEXT_PUBLIC_ to be visible in the browser

# Backend API URL (NestJS)
NEXT_PUBLIC_API_URL=http://localhost:5000

# WebSocket server URL (for real-time chat, matches, lobbies)
NEXT_PUBLIC_SOCKET_URL=http://localhost:5000

# ─── End of Environment Variables ──────────────────────────────────
