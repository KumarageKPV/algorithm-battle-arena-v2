# Database (matches docker-compose postgres service)
DATABASE_URL=postgresql://postgres:dev@postgres:5432/algorithm_battle_arena

# Redis (matches docker-compose redis service)
REDIS_URL=redis://redis:6379

# JWT
JWT_SECRET=change-me-in-production
JWT_EXPIRY=7d

# Password hashing key (must match the value used to hash existing passwords)
PASSWORD_KEY=change-me-in-production

# Admin credentials (no DB row — validated in AuthService)
ADMIN_EMAIL=admin@aba.com
ADMIN_PASSWORD=Admin1234!

# Judge0 (matches docker-compose judge0 service)
JUDGE0_API_URL=http://judge0:2358

# App
NODE_ENV=development
PORT=5000

