# ─── Root Environment Variables (Docker Compose) ──────────────────
# These variables are used by docker-compose.yml when running containers
# For local development, these are applied to the API and other services

# ─── Database (PostgreSQL) ────────────────────────────────────────
# Local Docker: postgresql://postgres:dev@localhost:5432/algorithm_battle_arena
# Supabase: postgresql://postgres.XXXXXXXXXXX.supabase.co:5432/postgres
DATABASE_URL=postgresql://postgres.njckgdppfbtxkiiaddwm:[YOUR-PASSWORD]@aws-1-ap-northeast-1.pooler.supabase.com:5432/postgres

# ─── Redis (Real-time features, caching) ──────────────────────────
# Local Docker: redis://default:password@localhost:6379
# Upstash Cloud: redis://default:TOKEN@HOST.upstash.io:6379
REDIS_URL=redis://default:[YOUR-UPSTASH-PASSWORD]@[YOUR-UPSTASH-HOST].upstash.io:6379
UPSTASH_REDIS_REST_URL=https://[YOUR-UPSTASH-HOST].upstash.io
UPSTASH_REDIS_REST_TOKEN=[YOUR-UPSTASH-REST-TOKEN]

# ─── Authentication & Security ────────────────────────────────────
# JWT Secret (min 64 chars for HS512)
# Generate: openssl rand -base64 32
JWT_SECRET=change-me-in-production

# Token expiry times (in seconds)
ACCESS_TOKEN_TTL_SECONDS=900
REFRESH_TOKEN_TTL_SECONDS=604800

# Password hashing key (PBKDF2 - must be consistent!)
PASSWORD_KEY=change-me-in-production

# ─── Admin Account (Hardcoded in AuthService) ─────────────────────
# Initial login credentials (before any DB seeding)
ADMIN_EMAIL=admin@aba.com
ADMIN_PASSWORD=Admin1234!

# ─── Judge0 (Code Execution Engine) ───────────────────────────────
# Use JUDGE0_URL + JUDGE0_AUTH_TOKEN for a deployed Judge0 instance
# Leave JUDGE0_URL empty to use the local docker-compose Judge0 service
JUDGE0_URL=
JUDGE0_AUTH_TOKEN=
JUDGE0_API_URL=http://judge0:2358
JUDGE0_MAX_POLL_ATTEMPTS=20
JUDGE0_POLL_INTERVAL_MS=500

# ─── OpenAI (Optional - for AI micro-course generation) ──────────
# Get key from: https://platform.openai.com/api-keys
# If not set, the system will use local fallback learning guides
OPENAI_API_KEY=

# ─── Application Settings ─────────────────────────────────────────
NODE_ENV=development
PORT=5000

# ─── End of Environment Variables ──────────────────────────────────

